generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  password     String
  deleted      Boolean  @default(false)
  orders       Order[]
  sessions     Session[]
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model Order {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  userId        Int
  total         Float
  status        String   @default("pending")
  user          User     @relation(fields: [userId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  name      String
  price     Float
  quantity  Int
  order     Order    @relation(fields: [orderId], references: [id])
}